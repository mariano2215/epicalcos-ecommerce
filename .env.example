# Variables de entorno de las Netlify Functions (epicalcos)
#
# En PRODUCCIÓN se cargan en: Netlify → Site settings → Environment variables
# (y hay que redeployar para que tomen efecto).
#
# Para desarrollo local con `netlify dev`, copiá este archivo a `.env` y completá.

# Mercado Pago (Checkout Pro) — access token de la cuenta (TEST o producción)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# Firma secreta de los webhooks de MP (panel → Tu app → Webhooks → Firma secreta).
# Valida que las notificaciones vengan realmente de Mercado Pago.
# También se acepta el nombre MERCADOPAGO_WEBHOOK_SECRET.
MP_WEBHOOK_SECRET=...
# Opcional: "1" para rechazar también notificaciones SIN firma (activar cuando
# los logs del webhook muestren "firma ok" consistentemente).
# MP_WEBHOOK_STRICT=1

# Notion CRM — token de la integración interna "EPICALCOS Ecommerce"
# (Notion → Conexiones → EPICALCOS Ecommerce → "Copiar token de acceso")
# IMPORTANTE: la integración debe tener acceso a la página/base "CRM EPICALCOS"
# (abrí la base → menú "•••" → Conexiones → agregá la integración).
NOTION_TOKEN=ntn_...

# Opcional: ID de la base CRM EPICALCOS. Ya viene por default en el código,
# solo seteala si querés apuntar a otra base.
NOTION_CRM_DATABASE_ID=a2e218a7fa0a422a9d03a8efd965670b

# Resend — para el email de aviso de pedido (opcional, no bloquea el checkout)
RESEND_API_KEY=re_...

# URL del sitio. En prod la setea Netlify sola; en local apuntá al dev server.
URL=http://localhost:8888

# ── CRM interno (app.epicalcos.com) — integración OPCIONAL ──────────────
# Si estas dos variables no están, el sitio NO envía nada al CRM (no-op).
# CRM_WEBHOOK_URL: endpoint del webhook del CRM.
# CRM_WEBHOOK_SECRET: el MISMO valor que EPICALCOS_WEBHOOK_SECRET en el site
# del CRM (generar con: openssl rand -hex 32).
# Rollback: borrar ambas variables (no hace falta revertir código).
# CRM_WEBHOOK_URL=https://app.epicalcos.com/api/webhooks/website-order
# CRM_WEBHOOK_SECRET=...
