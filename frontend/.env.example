# Dejar vacío en producción (usa Netlify Functions en mismo dominio).
# Setear solo en dev local si querés apuntar al backend Express:
#   VITE_API_URL=http://localhost:3001
VITE_API_URL=

# Analytics (opcional — dejar vacío para desactivar)
VITE_GTM_ID=
VITE_GA4_ID=
VITE_META_PIXEL_ID=

# Subida de diseños de /personalizados a Cloudinary (opcional).
# Si están vacías, el cliente manda los diseños por WhatsApp (fallback).
# Para activar: crear cuenta gratis en cloudinary.com y un "upload preset"
# de tipo UNSIGNED, y pegar acá el cloud name y el nombre del preset.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
